{
  "info": {
    "_postman_id": "d3c9c5d7-0e86-4b47-8f6b-0c5f4b9f2a01",
    "name": "E-commerce Event-Driven Architecture - Smoke Tests",
    "description": "Coleccion para validar autenticacion, flujo de pedidos y health checks del backend con variables de entorno locales.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const timestamp = Date.now();",
          "pm.environment.set('correlationId', `pm-${timestamp}-${Math.random().toString(16).slice(2, 8)}`);",
          "if (!pm.environment.get('createdOrderNumber')) {",
          "  pm.environment.set('createdOrderNumber', `ORD-${timestamp}`);",
          "}",
          "if (!pm.environment.get('invoiceNumber')) {",
          "  pm.environment.set('invoiceNumber', `INV-${timestamp}`);",
          "}",
          "if (!pm.environment.get('trackingNumber')) {",
          "  pm.environment.set('trackingNumber', `TRK-${timestamp}`);",
          "}",
          "if (!pm.environment.get('customerId')) {",
          "  pm.environment.set('customerId', '1001');",
          "}",
          "if (!pm.environment.get('productId')) {",
          "  pm.environment.set('productId', '501');",
          "}",
          "if (!pm.environment.get('paymentId')) {",
          "  pm.environment.set('paymentId', '701');",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login admin",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Correlation-Id",
                "value": "{{correlationId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{orderServiceUrl}}/api/v1/auth/login",
              "host": [
                "{{orderServiceUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "description": "Obtiene el JWT de demostracion y lo guarda en `accessToken` para el resto de la collection."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login responde 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var body = pm.response.json();",
                  "pm.environment.set('accessToken', body.token);",
                  "pm.environment.set('tokenType', body.tokenType || 'Bearer');",
                  "pm.environment.set('activeUser', body.username || 'admin');",
                  "pm.test('JWT recibido', function () {",
                  "  pm.expect(pm.environment.get('accessToken')).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
