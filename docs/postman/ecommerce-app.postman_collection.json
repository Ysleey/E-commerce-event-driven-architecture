        {
          "name": "Create order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Correlation-Id",
                "value": "{{correlationId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": {{customerId}},\n  \"productId\": {{productId}},\n  \"paymentId\": {{paymentId}},\n  \"orderNumber\": \"{{createdOrderNumber}}\",\n  \"invoiceNumber\": \"{{invoiceNumber}}\",\n  \"notes\": \"Smoke test generado desde Postman\",\n  \"customerContact\": {\n    \"customerName\": \"{{customerName}}\",\n    \"customerEmail\": \"{{customerEmail}}\",\n    \"customerPhone\": \"{{customerPhone}}\"\n  },\n  \"financials\": {\n    \"price\": {{price}},\n    \"discountAmount\": {{discountAmount}},\n    \"taxAmount\": {{taxAmount}},\n    \"shippingAmount\": {{shippingAmount}},\n    \"totalAmount\": {{totalAmount}},\n    \"couponCode\": \"POSTMAN-10\",\n    \"currency\": \"{{currency}}\"\n  },\n  \"shippingInfo\": {\n    \"paymentMethod\": \"{{paymentMethod}}\",\n    \"shippingMethod\": \"{{shippingMethod}}\",\n    \"trackingNumber\": \"{{trackingNumber}}\",\n    \"shippingAddress\": \"{{shippingAddress}}\",\n    \"billingAddress\": \"{{billingAddress}}\"\n  }\n}"
            },
            "url": {
              "raw": "{{orderServiceUrl}}/api/orders",
              "host": [
                "{{orderServiceUrl}}"
              ],
              "path": [
                "api",
                "orders"
              ]
            },
            "description": "Crea una orden base que alimenta el resto del smoke test."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Create order responde 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "var body = pm.response.json();",
                  "pm.environment.set('orderId', String(body.id));",
                  "pm.environment.set('createdOrderNumber', body.orderNumber || pm.environment.get('createdOrderNumber'));",
                  "pm.environment.set('trackingNumber', body.shippingInfo && body.shippingInfo.trackingNumber ? body.shippingInfo.trackingNumber : pm.environment.get('trackingNumber'));",
                  "pm.environment.set('lastOrderStatus', body.status || 'CREATED');",
                  "pm.test('Se guardo el orderId', function () {",
                  "  pm.expect(pm.environment.get('orderId')).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ]
        },
